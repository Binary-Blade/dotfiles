# Config aliases
alias config='cd ~/.config/binaryvim/lua && nvim .'
alias c-fier='cd ~/.config/tmux/.tmuxifier/layouts/ && nvim .'
alias c-envman='cd ~/.config/envman/ && nvim .'

# Docker aliases
alias lzd='lazydocker'
alias du='docker-compose up -d'
alias du-d='docker-compose up -d'
alias dd='docker-compose down'

# Git aliases
alias lzg='lazygit'

# JS/TS aliases
alias dev-js='cd ~/developer/workspace/JS_TS'
alias dev-vue='cd ~/developer/workspace/JS_TS/vuejs'
alias dev-react='cd ~/developer/workspace/JS_TS/REACT'
alias dev-nest='cd ~/developer/workspace/JS_TS/NESTJS'

# NeoVim aliases
alias nvim='NVIM_APPNAME="binaryvim" nvim'
alias obsidian='cd ~/developer/dev-doc/obsidian-software'

# PHP aliases
alias dev-php='cd ~/developer/workspace/php'
alias dev-laravel='cd ~/developer/workspace/php/LARAVEL'
alias sail='sh $([ -f sail ] && echo sail || echo vendor/bin/sail)'

# Python aliases
alias dev-py='cd ~/developer/workspace/python'
alias py='python3'
alias pip='pip3'

# Software aliases
alias dev-c='cd ~/developer/workspace/c'
alias dev-rust='cd ~/developer/workspace/RUST'

# Terminal aliases
alias c='clear'
alias e='exit'
alias zshrc='nvim ~/.zshrc'

# Tmux aliases
alias tx-project='tmuxifier load-session dev-project'
alias tx-ts='tmuxifier load-session dev-typescript'
alias tx-php='tmuxifier load-session dev-php'
alias tx-recall='tmuxifier load-session dev-recall'
alias tx-config='tmuxifier load-session config'
